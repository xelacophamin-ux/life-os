{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Python static server",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8000"],
      "port": 8000
    },
    {
      "name": "Node serve (npx)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["-y", "serve", "-l", "3000", "."],
      "port": 3000
    }
  ]
}
